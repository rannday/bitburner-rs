[
  {
    "label": "Bitburner: sync workspace",
    "command": "bbrs",
    "args": [
      "sync",
      "$ZED_WORKTREE_ROOT",
      "scripts",
      "--server",
      "home",
      "--addr",
      "127.0.0.1:12525"
    ],
    "reveal": "always",
    "hide": "never",
    "allow_concurrent_runs": false,
    "use_new_terminal": false
  }
]
